// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - name: string (required)
//   - avatarUrl: string (optional)
//
// Collection: categories
// Fields:
//   - name: string (required)
//   - description: string (optional)
//
// Collection: challenges
// Fields:
//   - title: string (required)
//   - description: string (required)
//   - categoryId: string (required)
//   - imageUrl: string (optional)
//   - youtubeUrl: string (optional)
//   - scoringType: string (optional, enum: ['TIME_ASC', 'TIME_DESC', 'COUNT_DESC'])
//
// Collection: results
// Fields:
//   - userId: string (required)
//   - userName: string (required)
//   - userAvatar: string (optional)
//   - challengeId: string (required)
//   - challengeTitle: string (optional)
//   - timeMs: int (required)
//   - score: float (optional)
//   - timestamp: timestamp (required)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "queenzz.app@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() < 1000));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidChallenge(data) {
      return data.keys().hasAll(['title', 'description', 'categoryId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.categoryId is string &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('youtubeUrl' in data) || (data.youtubeUrl is string && data.youtubeUrl.size() < 1000)) &&
             (!('scoringType' in data) || (data.scoringType in ['TIME_ASC', 'TIME_DESC', 'COUNT_DESC']));
    }

    function isValidResult(data) {
      return data.keys().hasAll(['userId', 'challengeId', 'timeMs', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.timeMs is int && data.timeMs >= 0 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCategory(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChallenge(request.resource.data);
      allow update, delete: if isAdmin();

      match /files/{fileId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidResult(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
